{
  "extends": [
    "config:recommended",
    ":preserveSemverRanges",
    ":ignoreUnstable",
    ":respectLatest",
    ":semanticCommits",
    ":pinAllExceptPeerDependencies",
    "npm:unpublishSafe",
    "helpers:pinGitHubActionDigests",
    "security:minimumReleaseAgeNpm",
  ],
  "separateMultipleMajor": true,
  "dependencyDashboard": true,
  "prHourlyLimit": 0,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchPackageNames": [
        "node"
      ],
      "enabled": false
    }
  ]
}
